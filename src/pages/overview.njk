---
layout: layouts/base.njk
permalink: /overview.html
pageTitle: All Reports Overview | Top Task Dashboard
brandDescription: High-level overview of every available report.
assetPrefix: ./
navPrefix: ./
reportsBase: ./reports
pageScript: overview.js
---
<main class="overview-layout">
  <section class="panel">
    <div class="overview-toolbar">
      <h2>Portfolio Summary</h2>
      <div class="overview-actions">
        <p id="overview-count" class="subtle"></p>
        <button id="download-spreadsheet" type="button">Download Portfolio CSV</button>
      </div>
    </div>
    <div id="overview-stats" class="stat-grid"></div>
  </section>

  <section class="panel">
    <h2>Reports at a Glance</h2>
    <div class="table-wrap">
      <table class="task-table">
        <thead>
          <tr>
            <th>Report</th>
            <th>Status</th>
            <th>Audience</th>
            <th>Total Tasks</th>
            <th>
              <span class="tooltip-label">
                Avg Score
                <button
                  class="info-tooltip"
                  type="button"
                  aria-label="How Avg Score is calculated"
                  aria-describedby="avg-score-tooltip"
                >
                  i
                </button>
                <span id="avg-score-tooltip" class="tooltip-content" role="tooltip">
                  Avg Score is the mean of each task's composite score in the report. Composite score is based on
                  Frequency, Impact, Findability, and Completability (1–5 each).
                </span>
              </span>
            </th>
            <th>Top Tasks</th>
            <th>Secondary</th>
            <th>Tiny</th>
          </tr>
        </thead>
        <tbody id="overview-table-body"></tbody>
      </table>
    </div>
  </section>
</main>
