{
  "name": "top-task-dashboard",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build:index": "node scripts/build-report-index.mjs",
    "validate:reports": "node scripts/validate-reports.mjs",
    "check": "npm run build:index && npm run validate:reports",
    "dev:11ty": "eleventy --serve",
    "dev:vite": "vite",
    "dev": "npm run dev:11ty & npm run dev:vite",
    "build:site": "eleventy",
    "build:assets": "vite build",
    "build": "npm run check && npm run build:site && npm run build:assets"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "sass": "^1.93.2",
    "vite": "^7.1.10"
  }
}
